# ─── SmarTime Backend — Environment Variables ──────────────────────────────
# Copia este archivo como .env y completa los valores reales.
# NUNCA subas .env a git.

# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# ─── PostgreSQL ─────────────────────────────────────────────────────────────
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_db
DATABASE_URL=postgresql://postgres:tu_contraseña@localhost:5432/smartime
DB_SSL=false

# ─── JWT (Access Token) ──────────────────────────────────────────────────────
# Genera con: node -e "require('crypto').randomBytes(64).toString('hex') |> console.log"
JWT_SECRET=CAMBIA_ESTO_POR_UN_SECRET_DE_64_BYTES_MINIMO
JWT_EXPIRES_IN=15m

# ─── Refresh Token ───────────────────────────────────────────────────────────
REFRESH_TOKEN_SECRET=CAMBIA_ESTO_POR_OTRO_SECRET_DIFERENTE_64_BYTES
REFRESH_TOKEN_EXPIRES_IN=7d
REFRESH_TOKEN_COOKIE_NAME=smartime_rt

# ─── Cookie Signing ──────────────────────────────────────────────────────────
COOKIE_SECRET=CAMBIA_ESTO_POR_UN_SECRET_PARA_FIRMAR_COOKIES

# ─── Telegram Bot ────────────────────────────────────────────────────────────
# Obtén el token de @BotFather en Telegram
TELEGRAM_BOT_TOKEN=CAMBIA_ESTO_POR_OTRO_TOKEN
# ID de Telegram del administrador principal del sistema
TELEGRAM_ADMIN_ID=ID_ADMIN

# ─── IMAP Password Encryption (AES-256-GCM) ──────────────────────────────────
# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
IMAP_ENCRYPTION_KEY=CAMBIA_ESTO_POR_32_BYTES_HEX_64_CHARS

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_GENERAL_MAX=100
RATE_LIMIT_AUTH_MAX=10

# ─── OTP ─────────────────────────────────────────────────────────────────────
OTP_EXPIRY_SECONDS=60
OTP_MAX_ATTEMPTS=5
OTP_BLOCK_DURATION_MINUTES=15
